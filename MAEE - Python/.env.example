# ==========================================
# LLM Provider Configurations
# ==========================================
OPENAI_API_KEY=your_openai_api_key_here
# NVIDIA_API_KEY=your_nvidia_api_key_here

# ==========================================
# LangSmith / LangChain Tracing
# ==========================================
# Tracing helps you log, debug, and evaluate your AI agent's thought process
# and LLM interactions under the hood. It is highly recommended!
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=ssd_workshop_project

# ==========================================
# Firebase Setup (for src/firebase_utils.py)
# ==========================================
FIREBASE_CREDENTIALS_PATH=path/to/your/firebase-credentials.json

# ==========================================
# Server Configuration
# ==========================================
PORT=5000
HOST=0.0.0.0
